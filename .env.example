# ============================================================
# TERAMONT PRIVATE RIDES — Variables de entorno
# ============================================================
# Copia este archivo como .env.local y completa los valores

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu-service-role-key

# ----- Wompi Colombia -----
# Obtén estas claves en: https://comercios.wompi.co
WOMPI_PUBLIC_KEY=pub_stagtest_...
WOMPI_PRIVATE_KEY=prv_stagtest_...
WOMPI_INTEGRITY_KEY=stagtest_integrity_...
WOMPI_EVENTS_SECRET=stagtest_events_...
WOMPI_ENVIRONMENT=sandbox
# Para producción: WOMPI_ENVIRONMENT=production

# ----- App -----
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Para producción: NEXT_PUBLIC_BASE_URL=https://tudominio.com

# ----- Contacto público -----
NEXT_PUBLIC_WHATSAPP_NUMBER=573001234567
NEXT_PUBLIC_CONTACT_EMAIL=hola@teramontrides.com

# ----- Email (Resend) — opcional -----
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@teramontrides.com
